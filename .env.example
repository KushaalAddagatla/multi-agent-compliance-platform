# ── LLM APIs ──────────────────────────────────────────────────────────
# Claude (chat reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings: text-embedding-ada-002, 1536 dims)
OPENAI_API_KEY=sk-...

# ── AWS ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── AWS SES ───────────────────────────────────────────────────────────
SES_FROM_EMAIL=compliance@yourdomain.com
SES_TO_EMAIL=team@yourdomain.com

# ── S3 ────────────────────────────────────────────────────────────────
S3_REPORTS_BUCKET=compliance-reports

# ── SQS ───────────────────────────────────────────────────────────────
SQS_SCAN_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/compliance-scan-queue

# ── Database (override for prod) ──────────────────────────────────────
# DB_URL=jdbc:postgresql://prod-host:5432/compliance
# DB_USERNAME=compliance
# DB_PASSWORD=...

# ── Local dev overrides (set when running with -Dspring.profiles.active=local) ──
# AWS_ENDPOINT_OVERRIDE=http://localhost:4566
